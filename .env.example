# Production .env — copy to .env and fill in real values for production deploys.
# For local development, docker compose up works out of the box with no .env file.
#
# POSTGRES_PASSWORD: generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
DOMAIN=yourdomain.example
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://finance:CHANGE_ME_GENERATE_A_STRONG_PASSWORD@postgres:5432/finance
PDF_STORAGE_PATH=/data/pdfs
CLASSIFICATION_MIN_SIMILARITY=0.30
CLASSIFICATION_K=3
